<h1>New game</h1>

<ul class="display_grid">
  <% @grid.each do |letter|%>
    <li class="letter"><%= letter %></li>
  <%end%>
</ul>

<p>What is the longest word you can find?</p>
<form action="/score" method="get">
  <input type="text" name="word" value="<%= params[:word] %>" placeholder="Enter your word">
  <input type="submit" name="play">
  <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
</form>
